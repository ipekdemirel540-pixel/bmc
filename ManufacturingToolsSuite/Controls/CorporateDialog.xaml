<Window x:Class="ManufacturingToolsSuite.Controls.CorporateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
  <Grid>
    <Border Background="Transparent"
            MouseLeftButtonDown="Backdrop_MouseLeftButtonDown"/>

    <Border x:Name="DialogCard"
            Margin="32"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Effect="{DynamicResource ShadowEffectHigh}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MinWidth="360"
            MaxWidth="480">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Height="4"
                CornerRadius="16,16,0,0"
                x:Name="AccentBar"
                Background="{DynamicResource AccentBrush}"/>

        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="IconGlyph"
                       Text="&#xE946;"
                       FontFamily="{DynamicResource IconFont}"
                       FontSize="22"
                       Foreground="{DynamicResource InfoBrush}"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"/>

            <TextBlock x:Name="TitleText"
                       Grid.Column="1"
                       Text="Bilgi"
                       FontFamily="{DynamicResource PrimaryFont}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
          </Grid>
        </Border>

        <TextBlock x:Name="MessageText"
                   Grid.Row="2"
                   Margin="20,18,20,18"
                   FontFamily="{DynamicResource SecondaryFont}"
                   FontSize="13"
                   Foreground="{DynamicResource TextBrush}"
                   TextWrapping="Wrap"
                   LineHeight="20"/>

        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,16,16"
                Padding="16,12,16,16">
          <StackPanel x:Name="ButtonPanel"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"/>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
