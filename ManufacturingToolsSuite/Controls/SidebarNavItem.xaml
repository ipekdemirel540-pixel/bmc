<UserControl x:Class="ManufacturingToolsSuite.Controls.SidebarNavItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ManufacturingToolsSuite.Controls"
             x:Name="Root">
  <Button x:Name="NavButton"
          Style="{StaticResource SidebarNavButtonStyle}"
          Command="{Binding Command, ElementName=Root}"
          Click="NavButton_Click"
          Tag="{Binding IsSelected, ElementName=Root}">
    <Grid>
      <Border x:Name="AccentBar"
              Width="3"
              HorizontalAlignment="Left"
              CornerRadius="2"
              Margin="0,8,0,8"
              Visibility="Collapsed"
              Background="{Binding AccentBrush, ElementName=Root}"/>
      <StackPanel Orientation="Horizontal" Margin="14,0,12,0">
        <TextBlock Text="{Binding IconGlyph, ElementName=Root}"
                   FontFamily="{StaticResource IconFont}"
                   FontSize="18"
                   Foreground="{Binding AccentBrush, ElementName=Root}"
                   VerticalAlignment="Center"
                   Width="24"
                   TextAlignment="Center"/>
        <StackPanel x:Name="LabelPanel" Margin="12,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="{Binding Title, ElementName=Root}"
                     FontFamily="{StaticResource SecondaryFont}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextBrush}"/>
          <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                     FontFamily="{StaticResource SecondaryFont}"
                     FontSize="10"
                     Foreground="{DynamicResource SecondaryTextBrush}"
                     Margin="0,2,0,0"
                     TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </StackPanel>
    </Grid>
  </Button>
</UserControl>
