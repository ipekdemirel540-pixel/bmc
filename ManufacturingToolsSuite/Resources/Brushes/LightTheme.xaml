<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ManufacturingToolsSuite.Controls">
  <!-- Corporate Light Palette — warm slate enterprise -->
  <Color x:Key="Bg#">#F8FAFC</Color>
  <Color x:Key="Surface#">#FFFFFF</Color>
  <Color x:Key="Card#">#FFFFFF</Color>
  <Color x:Key="Border#">#E2E8F0</Color>
  <Color x:Key="Text#">#0F172A</Color>
  <Color x:Key="TextSecondary#">#64748B</Color>
  <Color x:Key="Accent#">#2563EB</Color>
  <Color x:Key="AccentMuted#">#EFF6FF</Color>
  <Color x:Key="IconContainer#">#F1F5F9</Color>
  <Color x:Key="HoverSurface#">#F8FAFC</Color>
  <Color x:Key="PressedSurface#">#EFF6FF</Color>
  <Color x:Key="Sidebar#">#FFFFFF</Color>
  <Color x:Key="SidebarActive#">#F1F5F9</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Bg#}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface#}"/>
  <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Card#}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border#}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource Text#}"/>
  <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondary#}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent#}"/>
  <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted#}"/>
  <SolidColorBrush x:Key="IconContainerBrush" Color="{StaticResource IconContainer#}"/>
  <SolidColorBrush x:Key="HoverSurfaceBrush" Color="{StaticResource HoverSurface#}"/>
  <SolidColorBrush x:Key="PressedSurfaceBrush" Color="{StaticResource PressedSurface#}"/>
  <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource Sidebar#}"/>
  <SolidColorBrush x:Key="SidebarNavActiveBrush" Color="{StaticResource SidebarActive#}"/>

  <!-- Module accent colors — corporate, restrained -->
  <SolidColorBrush x:Key="SAPAccentBrush" Color="#4F46E5"/>
  <SolidColorBrush x:Key="NestingAccentBrush" Color="#D97706"/>
  <SolidColorBrush x:Key="IOAccentBrush" Color="#2563EB"/>
  <SolidColorBrush x:Key="MakeBuyAccentBrush" Color="#7C3AED"/>
  <SolidColorBrush x:Key="BMCAIAccentBrush" Color="#0D9488"/>

  <LinearGradientBrush x:Key="SAPGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#6366F1" Offset="0"/>
    <GradientStop Color="#4F46E5" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="NestingGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#F59E0B" Offset="0"/>
    <GradientStop Color="#D97706" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="STPGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#EF4444" Offset="0"/>
    <GradientStop Color="#DC2626" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="IOGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#3B82F6" Offset="0"/>
    <GradientStop Color="#2563EB" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="MakeBuyGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#8B5CF6" Offset="0"/>
    <GradientStop Color="#7C3AED" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="BMCAIGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#14B8A6" Offset="0"/>
    <GradientStop Color="#0D9488" Offset="1"/>
  </LinearGradientBrush>

  <!-- Fonts -->
  <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
  <FontFamily x:Key="PrimaryFont">Segoe UI Variable Display, Segoe UI Semibold, Segoe UI, sans-serif</FontFamily>
  <FontFamily x:Key="SecondaryFont">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>

  <!-- Shadows -->
  <DropShadowEffect x:Key="ShadowEffectLow" Color="#0F172A" ShadowDepth="0" BlurRadius="16" Opacity="0.06"/>
  <DropShadowEffect x:Key="ShadowEffectMedium" Color="#0F172A" ShadowDepth="2" BlurRadius="12" Opacity="0.08"/>
  <DropShadowEffect x:Key="ShadowEffectHigh" Color="#0F172A" ShadowDepth="4" BlurRadius="20" Opacity="0.12"/>
  <DropShadowEffect x:Key="CardShadowEffect" Color="#0F172A" ShadowDepth="1" BlurRadius="10" Opacity="0.07"/>
  <DropShadowEffect x:Key="CardShadowHoverEffect" Color="#2563EB" ShadowDepth="2" BlurRadius="16" Opacity="0.12"/>
  <DropShadowEffect x:Key="IconShadowEffect" Color="#000000" ShadowDepth="0" BlurRadius="0" Opacity="0"/>

  <!-- Base Button -->
  <Style x:Key="BaseButton" TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="FontFamily" Value="{StaticResource SecondaryFont}"/>
    <Setter Property="FontSize" Value="13"/>
  </Style>

  <!-- TitleBar -->
  <Style x:Key="TitleBarBrandLogoStyle" TargetType="Image">
    <Setter Property="Source" Value="/Resources/Images/uretim-teknolojileri-ekibi.png"/>
    <Setter Property="Stretch" Value="Uniform"/>
    <Setter Property="Width" Value="22"/>
    <Setter Property="Height" Value="22"/>
    <Setter Property="Opacity" Value="0.92"/>
    <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style x:Key="TitleBarAppNameStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style x:Key="TitleBarGlyphStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style x:Key="TitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
    <Setter Property="Width" Value="32"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Margin" Value="1,0,0,0"/>
    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="PART_Border" Background="Transparent" CornerRadius="6">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource TitleBarHoverBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource TitleBarPressedBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="PART_Border" Background="Transparent" CornerRadius="6">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource TitleBarCloseHoverBrush}"/>
              <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource TitleBarClosePressedBrush}"/>
              <Setter Property="Foreground" Value="White"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="HeaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
    <Setter Property="Width" Value="28"/>
    <Setter Property="Height" Value="28"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="PART_Border" Background="Transparent" CornerRadius="6"
                  BorderBrush="Transparent" BorderThickness="1">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
              <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="NavigationButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
    <Setter Property="Width" Value="36"/>
    <Setter Property="Height" Value="36"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="PART_Border" Background="Transparent"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
              <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ThemeToggleStyle" TargetType="ToggleButton">
    <Setter Property="Width" Value="52"/>
    <Setter Property="Height" Value="28"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="IsChecked" Value="True"/>
    <Setter Property="ToolTip" Value="Tema değiştir"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Grid Width="52" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border x:Name="Track" Background="#E2E8F0" CornerRadius="11"
                    BorderBrush="#CBD5E1" BorderThickness="1"/>
            <TextBlock x:Name="TrackSun" Text="&#xE706;"
                       FontFamily="{StaticResource IconFont}" FontSize="9"
                       Foreground="#94A3B8" HorizontalAlignment="Left"
                       VerticalAlignment="Center" Margin="7,0,0,0" Opacity="0.55"/>
            <TextBlock x:Name="TrackMoon" Text="&#xE708;"
                       FontFamily="{StaticResource IconFont}" FontSize="9"
                       Foreground="#94A3B8" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Margin="0,0,7,0" Opacity="0.55"/>
            <Grid x:Name="SliderGrid" HorizontalAlignment="Right" Margin="0,1,1,1">
              <Border x:Name="Thumb" Background="#FFFFFF" CornerRadius="10" Width="20" Height="20">
                <Border.Effect>
                  <DropShadowEffect Color="#0F172A" ShadowDepth="0" BlurRadius="4" Opacity="0.12"/>
                </Border.Effect>
                <TextBlock x:Name="ThumbIcon" Text="&#xE706;"
                           FontFamily="{StaticResource IconFont}" FontSize="10"
                           Foreground="#D97706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
            </Grid>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="False">
              <Setter TargetName="Track" Property="Background" Value="#334155"/>
              <Setter TargetName="Track" Property="BorderBrush" Value="#475569"/>
              <Setter TargetName="SliderGrid" Property="HorizontalAlignment" Value="Left"/>
              <Setter TargetName="SliderGrid" Property="Margin" Value="1,1,0,1"/>
              <Setter TargetName="Thumb" Property="Background" Value="#F8FAFC"/>
              <Setter TargetName="ThumbIcon" Property="Text" Value="&#xE708;"/>
              <Setter TargetName="ThumbIcon" Property="Foreground" Value="#1E293B"/>
              <Setter TargetName="TrackSun" Property="Opacity" Value="0.25"/>
              <Setter TargetName="TrackMoon" Property="Opacity" Value="0.7"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Thumb" Property="RenderTransform">
                <Setter.Value>
                  <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                </Setter.Value>
              </Setter>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Module card button -->
  <Style x:Key="FlatIconButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="PART_Border"
                  Background="{DynamicResource CardBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="24,20"
                  Effect="{StaticResource CardShadowEffect}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
              <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="PART_Border" Property="Effect" Value="{StaticResource CardShadowHoverEffect}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
              <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ModuleTileButtonStyle" BasedOn="{StaticResource FlatIconButtonStyle}" TargetType="Button"/>

  <Style x:Key="DashboardModuleCardButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatIconButtonStyle}">
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="PART_Border"
                  Background="{DynamicResource CardBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="22,22"
                  MinHeight="172"
                  Effect="{StaticResource CardShadowEffect}">
            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
              <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="PART_Border" Property="Effect" Value="{StaticResource CardShadowHoverEffect}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
              <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ModuleTileCardButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatIconButtonStyle}">
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="VerticalContentAlignment" Value="Top"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="PART_Border"
                  Background="{DynamicResource CardBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="14"
                  Padding="28,26"
                  MinHeight="192"
                  Effect="{StaticResource CardShadowEffect}">
            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
              <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="PART_Border" Property="Effect" Value="{StaticResource CardShadowHoverEffect}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
              <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SecondaryButton" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,10"/>
    <Setter Property="FontFamily" Value="{StaticResource SecondaryFont}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
              <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="NestingSubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="BorderBrush" Value="#FDE68A"/>
    <Setter Property="Foreground" Value="#B45309"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd"
                  Background="#FFFBEB"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="#FEF3C7"/>
              <Setter TargetName="bd" Property="BorderBrush" Value="#F59E0B"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Background" Value="#FDE68A"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="NestingSecondaryActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="Padding" Value="12,7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
              <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ScrollViewer">
    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
  </Style>
  <Style TargetType="Frame">
    <Setter Property="NavigationUIVisibility" Value="Hidden"/>
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFFFFF" Offset="0"/>
    <GradientStop Color="#FAFBFC" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="FooterGradient" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#F8FAFC" Offset="0"/>
    <GradientStop Color="#F1F5F9" Offset="1"/>
  </LinearGradientBrush>

  <Style x:Key="HeroCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Padding" Value="32,28"/>
    <Setter Property="Effect" Value="{StaticResource CardShadowEffect}"/>
  </Style>

  <Style x:Key="PillIconButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
    <Setter Property="Width" Value="36"/>
    <Setter Property="Height" Value="36"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="Base" Background="{TemplateBinding Background}" CornerRadius="8"/>
            <Border x:Name="Hover" Background="{DynamicResource HoverSurfaceBrush}" CornerRadius="8" Opacity="0"/>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Hover" Property="Opacity" Value="1"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Hover" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
              <Setter TargetName="Hover" Property="Opacity" Value="1"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="FooterCardStyle" TargetType="Border">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
  </Style>

  <Style x:Key="ModuleTileV2Style" TargetType="controls:ModuleTile">
    <Setter Property="Width" Value="NaN"/>
    <Setter Property="Height" Value="NaN"/>
    <Setter Property="MinHeight" Value="192"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="Opacity" Value="1"/>
  </Style>

  <Style x:Key="HeroEyebrowStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource SecondaryFont}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
  </Style>

  <!-- Semantic status colors -->
  <SolidColorBrush x:Key="SuccessBrush" Color="#059669"/>
  <SolidColorBrush x:Key="SuccessMutedBrush" Color="#ECFDF5"/>
  <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
  <SolidColorBrush x:Key="WarningMutedBrush" Color="#FFFBEB"/>
  <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626"/>
  <SolidColorBrush x:Key="ErrorMutedBrush" Color="#FEF2F2"/>
  <SolidColorBrush x:Key="InfoBrush" Color="#2563EB"/>
  <SolidColorBrush x:Key="InfoMutedBrush" Color="#EFF6FF"/>
  <SolidColorBrush x:Key="DialogOverlayBrush" Color="#660F172A"/>
  <SolidColorBrush x:Key="TitleBarHoverBrush" Color="#F1F5F9"/>
  <SolidColorBrush x:Key="TitleBarPressedBrush" Color="#E2E8F0"/>
  <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#DC2626"/>
  <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#B91C1C"/>
  <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>

  <!-- Page shell -->
  <Style x:Key="PageShell" TargetType="Grid">
    <Setter Property="Margin" Value="32,24,32,28"/>
    <Setter Property="MinHeight" Value="0"/>
  </Style>

  <Style x:Key="PageShellCompact" TargetType="Grid">
    <Setter Property="Margin" Value="24,16,24,28"/>
    <Setter Property="MinHeight" Value="0"/>
