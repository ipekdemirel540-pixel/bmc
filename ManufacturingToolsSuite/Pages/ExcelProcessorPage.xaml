<Page x:Class="ManufacturingToolsSuite.Pages.ExcelProcessorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:ManufacturingToolsSuite.Controls"
      Title="SAP Excel İşlemcisi"
      Background="{DynamicResource BackgroundBrush}">

  <Page.Resources>
    <!-- Simple, clean, standard TextBox style with rounded corners and dynamic colors -->
    <Style x:Key="SearchInputFieldStyle" TargetType="TextBox">
      <Setter Property="Height" Value="32"/>
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontFamily" Value="{StaticResource SecondaryFont}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Style.Resources>
        <Style TargetType="Border">
          <Setter Property="CornerRadius" Value="6"/>
        </Style>
      </Style.Resources>
      <Style.Triggers>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Page.Resources>

  <ScrollViewer Style="{StaticResource PageContentArea}">
    <Grid Style="{StaticResource PageShell}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*" MinHeight="0"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <Border Grid.Row="0" Style="{StaticResource PageHeaderBar}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE8F1;" Style="{StaticResource FlatModuleIcon}"
                     Foreground="{StaticResource SAPAccentBrush}"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="SAP Analizi" Style="{StaticResource ModulePageTitle}"/>
            <TextBlock Text="Excel veri işleme ve BOM analizi" Style="{StaticResource ModulePageSubtitle}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Main Workspace -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Left Main Card -->
        <Border Grid.Column="0" Style="{StaticResource CorporateCard}" Padding="0" MinHeight="400" VerticalAlignment="Stretch">
          <Grid>
            <!-- 1. EMPTY STATE (No File Loaded) -->
            <StackPanel x:Name="pnlEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400" Margin="24">
              <TextBlock Text="&#xE8F1;" Style="{StaticResource EmptyStateIcon}" FontSize="56"
                         Foreground="{StaticResource SAPAccentBrush}" Opacity="0.4"/>
              <TextBlock Text="SAP Excel İşlemcisi" FontFamily="{StaticResource PrimaryFont}" FontSize="18"
                         FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                         HorizontalAlignment="Center" Margin="0,16,0,8"/>
              <TextBlock Text="SAP BOM ve üretim verilerini Excel üzerinden içe aktarın, analiz edin ve raporlayın."
                         FontFamily="{StaticResource SecondaryFont}" FontSize="13"
                         Foreground="{DynamicResource SecondaryTextBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,24"/>
              <Button Style="{StaticResource PrimaryButton}" Background="{StaticResource SAPAccentBrush}"
                      Padding="24,12" HorizontalAlignment="Center" Click="SelectExcel_Click">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE8E5;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                  <TextBlock Text="Excel Dosyası Seç" FontWeight="SemiBold"/>
                </StackPanel>
              </Button>
            </StackPanel>

            <!-- 2. DATA VIEW STATE (File Loaded) -->
            <Grid x:Name="pnlDataState" Visibility="Collapsed" Margin="16">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="250"/>
              </Grid.RowDefinitions>

              <!-- Top Stats Summary -->
              <UniformGrid Grid.Row="0" Columns="3" Rows="1" Margin="0,0,0,16">
                <Border Style="{StaticResource StatStripCard}" Margin="0,0,4,0" Padding="12,8" CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="Parça Tipi" Style="{StaticResource MetricCardLabel}" FontSize="10"/>
                    <TextBlock x:Name="txtStatPartTypes" Text="0" Style="{StaticResource MetricCardValue}"
                               Foreground="{DynamicResource TextBrush}" FontSize="16" Margin="0,2,0,0"/>
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource StatStripCard}" Margin="2,0" Padding="12,8" CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="Toplam Parça Adedi" Style="{StaticResource MetricCardLabel}" FontSize="10"/>
                    <TextBlock x:Name="txtStatTotalPieces" Text="0" Style="{StaticResource MetricCardValue}"
                               Foreground="{DynamicResource TextBrush}" FontSize="16" Margin="0,2,0,0"/>
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource StatStripCard}" Margin="4,0,0,0" Padding="12,8" CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="Farklı Ölçü Grubu" Style="{StaticResource MetricCardLabel}" FontSize="10"/>
                    <TextBlock x:Name="txtStatDimensions" Text="0" Style="{StaticResource MetricCardValue}"
                               Foreground="{DynamicResource TextBrush}" FontSize="16" Margin="0,2,0,0"/>
                  </StackPanel>
                </Border>
              </UniformGrid>

              <!-- Search Strip -->
              <Grid Grid.Row="1" Margin="0,0,0,12">
                <TextBox x:Name="txtSearch" Style="{StaticResource SearchInputFieldStyle}"
                         TextChanged="TxtSearch_TextChanged" VerticalAlignment="Center"/>
                <TextBlock IsHitTestVisible="False" Text="Parça no, tanım veya kesit ara..."
                           Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="10,0,0,0">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </Grid>

              <!-- DataGrid -->
              <DataGrid Grid.Row="2" x:Name="dgBomRows"
                        Style="{StaticResource CorporateDataGrid}"
                        ColumnHeaderStyle="{StaticResource CorporateDataGridColumnHeader}"
                        CellStyle="{StaticResource CorporateDataGridCell}"
                        RowStyle="{StaticResource CorporateDataGridRow}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50"/>
                  <DataGridTextColumn Header="Bileşen No" Binding="{Binding ComponentNumber}" Width="110"/>
                  <DataGridTextColumn Header="Bileşen Adı" Binding="{Binding ComponentName}" Width="*"/>
                  <DataGridTextColumn Header="Ölçü" Binding="{Binding Dimensions}" Width="120"/>
                  <DataGridTextColumn Header="Adet" Binding="{Binding Quantity}" Width="65"/>
                  <DataGridTextColumn Header="Boy (m)" Binding="{Binding LengthMeters, StringFormat={}{0:F3}}" Width="70"/>
                  <DataGridTextColumn Header="Boy (mm)" Binding="{Binding LengthMm, StringFormat={}{0:N0}}" Width="80"/>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Grid>
        </Border>

        <!-- Right Action Sidebar -->
        <StackPanel Grid.Column="2">
          <!-- Always-Visible Formats Card (Collapsed when file is loaded, or stays secondary) -->
          <Border x:Name="cardNoFileActions" Style="{StaticResource CorporateCard}" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="Desteklenen Formatlar" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
              <TextBlock Text="· .xlsx / .xls Dosyaları" FontWeight="SemiBold" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
              <TextBlock Text="· SAP BOM Sabit Formatı:" Style="{StaticResource CaptionText}" Margin="10,0,0,2"/>
              <TextBlock Text="  B:Bileşen No, C:Ad, D:Adet, E:Ölçü, F:Boy (m)" Style="{StaticResource CaptionText}" Foreground="{DynamicResource MutedTextBrush}" Margin="15,0,0,8"/>
              <TextBlock Text="· Başlık Tabanlı Esnek Format:" Style="{StaticResource CaptionText}" Margin="10,0,0,2"/>
              <TextBlock Text="  Boy, Adet, Parça No, Ölçü başlıklarını otomatik eşleştirir." Style="{StaticResource CaptionText}" Foreground="{DynamicResource MutedTextBrush}" Margin="15,0,0,0"/>
            </StackPanel>
          </Border>

          <!-- File Information & Actions (Visible only when file loaded) -->
          <Border x:Name="cardFileLoadedActions" Style="{StaticResource CorporateCard}" Visibility="Collapsed">
            <StackPanel>
              <TextBlock Text="Dosya Detayları" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
              
              <TextBlock Text="Dosya Adı" Style="{StaticResource FieldLabel}"/>
              <TextBlock x:Name="lblFileName" Text="-" FontWeight="SemiBold" Style="{StaticResource CaptionText}" Margin="0,0,0,10" TextTrimming="CharacterEllipsis"/>

              <TextBlock Text="Format Tipi" Style="{StaticResource FieldLabel}"/>
              <TextBlock x:Name="lblFormatType" Text="-" FontWeight="SemiBold" Style="{StaticResource CaptionText}" Margin="0,0,0,16"/>

              <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

              <!-- Action buttons -->
              <Button Style="{StaticResource PrimaryButton}" Background="{StaticResource SAPAccentBrush}"
                      Margin="0,0,0,10" Padding="12,10" Click="SendToNesting_Click">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE8A9;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,8,0"/>
                  <TextBlock Text="Nesting Modülüne Gönder" FontWeight="SemiBold"/>
                </StackPanel>
              </Button>

              <Button Style="{StaticResource SecondaryButton}" Margin="0,0,0,16" Padding="12,8" Click="ExportCsv_Click">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE744;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,8,0"/>
                  <TextBlock Text="Farklı Kaydet (CSV)" FontWeight="SemiBold"/>
                </StackPanel>
              </Button>

              <Button Background="Transparent" BorderThickness="0" Foreground="{StaticResource WarningBrush}"
                      HorizontalAlignment="Center" FontWeight="SemiBold" Cursor="Hand" Padding="12,6" Click="Clear_Click">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE894;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                  <TextBlock Text="Dosyayı Temizle" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Grid>
  </ScrollViewer>
</Page>
