<Page x:Class="ManufacturingToolsSuite.Pages.ExcelProcessorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">

  <ScrollViewer Style="{StaticResource PageContentArea}">
    <Grid Style="{StaticResource PageShell}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Style="{StaticResource PageHeaderBar}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE8F1;" Style="{StaticResource FlatModuleIcon}"
                     Foreground="{StaticResource SAPAccentBrush}"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="SAP Analizi" Style="{StaticResource ModulePageTitle}"/>
            <TextBlock Text="Excel veri işleme ve BOM analizi" Style="{StaticResource ModulePageSubtitle}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CorporateCard}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400">
            <TextBlock Text="&#xE8F1;" Style="{StaticResource EmptyStateIcon}" FontSize="56"
                       Foreground="{StaticResource SAPAccentBrush}" Opacity="0.4"/>
            <TextBlock Text="SAP Excel İşlemcisi" FontFamily="{StaticResource PrimaryFont}" FontSize="18"
                       FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                       HorizontalAlignment="Center" Margin="0,16,0,8"/>
            <TextBlock Text="SAP BOM ve üretim verilerini Excel üzerinden içe aktarın, analiz edin ve raporlayın."
                       FontFamily="{StaticResource SecondaryFont}" FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
            <Button Style="{StaticResource PrimaryButton}" Background="{StaticResource SAPAccentBrush}"
                    Margin="0,24,0,0" Padding="24,12" HorizontalAlignment="Center">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8E5;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Text="Excel Dosyası Seç"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="2">
          <Border Style="{StaticResource CorporateCard}" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="Desteklenen Formatlar" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
              <TextBlock Text="· .xlsx / .xls" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
              <TextBlock Text="· SAP BOM export" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
              <TextBlock Text="· Malzeme listesi" Style="{StaticResource CaptionText}"/>
            </StackPanel>
          </Border>
          <Border Style="{StaticResource CorporateCard}">
            <StackPanel>
              <TextBlock Text="Durum" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
              <Border Style="{StaticResource StatusPill}">
                <TextBlock Text="Geliştirme aşamasında" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource WarningBrush}"/>
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Grid>
  </ScrollViewer>
</Page>
