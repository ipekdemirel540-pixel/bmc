<Page x:Class="ManufacturingToolsSuite.Pages.StepViewerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">

  <ScrollViewer Style="{StaticResource PageContentArea}">
    <Grid Style="{StaticResource PageShell}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Style="{StaticResource PageHeaderBar}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE8B7;" Style="{StaticResource FlatModuleIcon}"
                     Foreground="#DC2626"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="STEP / STP Görüntüleyici" Style="{StaticResource ModulePageTitle}"/>
            <TextBlock Text="3D CAD model görüntüleme ve inceleme" Style="{StaticResource ModulePageSubtitle}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Style="{StaticResource CorporateCard}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="280"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Background="{DynamicResource HoverSurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  CornerRadius="12" MinHeight="360">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="&#xE8B7;" Style="{StaticResource EmptyStateIcon}" FontSize="64" Opacity="0.3"/>
              <TextBlock Text="3D görüntüleyici alanı" FontFamily="{StaticResource SecondaryFont}" FontSize="13"
                         Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <StackPanel Grid.Column="2">
            <Border Style="{StaticResource CorporateCard}" Margin="0,0,0,12" Padding="16">
              <StackPanel>
                <TextBlock Text="Dosya" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,0,8">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8E5;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,8,0"/>
                    <TextBlock Text="STEP Dosyası Aç"/>
                  </StackPanel>
                </Button>
                <TextBlock Text="Desteklenen: .step, .stp" Style="{StaticResource CaptionText}"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CorporateCard}" Padding="16">
              <StackPanel>
                <TextBlock Text="Görünüm" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                <Button Content="Perspektif" Style="{StaticResource SecondaryButton}" Margin="0,0,0,6"/>
                <Button Content="Ön Görünüm" Style="{StaticResource SecondaryButton}" Margin="0,0,0,6"/>
                <Button Content="Üst Görünüm" Style="{StaticResource SecondaryButton}"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</Page>
