<Page x:Class="ManufacturingToolsSuite.Pages.NestingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:ManufacturingToolsSuite.Controls"
      Title="Nesting"
      Background="{DynamicResource BackgroundBrush}"
      VerticalAlignment="Stretch"
      HorizontalAlignment="Stretch">

  <Page.Resources>
    <!-- Simple, clean, standard TextBox style with rounded corners and dynamic colors -->
    <Style x:Key="NestingInputFieldStyle" TargetType="TextBox">
      <Setter Property="Height" Value="32"/>
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontFamily" Value="{StaticResource SecondaryFont}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Style.Resources>
        <!-- This rounds the corners of the native Microsoft TextBox Border -->
        <Style TargetType="Border">
          <Setter Property="CornerRadius" Value="6"/>
        </Style>
      </Style.Resources>
      <Style.Triggers>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Page.Resources>

  <Grid Style="{StaticResource PageShellCompact}"
        MinHeight="0"
        Margin="24,16,24,12"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MinHeight="0"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Compact KPI strip -->
    <UniformGrid Grid.Row="0" Columns="4" Rows="1" Margin="0,0,0,10">
      <Border Style="{StaticResource StatStripCard}" Margin="0,0,4,0" Padding="10,6" CornerRadius="8">
        <StackPanel>
          <TextBlock Text="Profil Sayısı" Style="{StaticResource MetricCardLabel}" FontSize="9"/>
          <TextBlock x:Name="txtMetricProfiles" Text="—" Style="{StaticResource MetricCardValue}"
                     Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,2,0,0"/>
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatStripCard}" Margin="2,0" Padding="10,6" CornerRadius="8">
        <StackPanel>
          <TextBlock Text="Standart Boy" Style="{StaticResource MetricCardLabel}" FontSize="9"/>
          <TextBlock x:Name="txtMetricStandard" Text="6000 mm" Style="{StaticResource MetricCardValue}"
                     Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,2,0,0"/>
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatStripCard}" Margin="2,0" Padding="10,6" CornerRadius="8">
        <StackPanel>
          <TextBlock Text="Toplam Fire" Style="{StaticResource MetricCardLabel}" FontSize="9"/>
          <TextBlock x:Name="txtMetricWaste" Text="—" Style="{StaticResource MetricCardValue}"
                     Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,2,0,0"/>
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatStripCard}" Margin="4,0,0,0" Padding="10,6" CornerRadius="8">
        <StackPanel>
          <TextBlock Text="Verimlilik" Style="{StaticResource MetricCardLabel}" FontSize="9"/>
          <TextBlock x:Name="txtMetricUtil" Text="—" Style="{StaticResource MetricCardValue}"
                     Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,2,0,0"/>
        </StackPanel>
      </Border>
    </UniformGrid>

    <!-- Main workspace -->
    <Grid Grid.Row="1" MinHeight="0" VerticalAlignment="Stretch">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="300" MinWidth="260"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*" MinWidth="280"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="220" MinWidth="200"/>
      </Grid.ColumnDefinitions>

      <!-- Input column (scrollable) -->
      <ScrollViewer Grid.Column="0"
                    MinHeight="0"
                    VerticalAlignment="Stretch"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Background="Transparent"
                    Padding="0,0,4,0"
                    CanContentScroll="False">
        <StackPanel Margin="0,0,0,32">
          <Border Style="{StaticResource CorporateCard}" Margin="0,0,0,10" Padding="16">
            <StackPanel>
              <TextBlock Text="Veri Kaynağı" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
              <Button Style="{StaticResource PrimaryButton}" Background="{StaticResource NestingAccentBrush}"
                      Click="SelectExcel_Click" Margin="0,0,0,10" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE8E5;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,6,0"/>
                  <TextBlock Text="SAP BOM Excel Seç"/>
                </StackPanel>
              </Button>
              <Border Style="{StaticResource InputFieldSurface}">
                <TextBlock x:Name="txtFileName" Text="Excel dosyası seçin..."
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="SAP BOM veya başlıklı profil listesi desteklenir" Style="{StaticResource CaptionText}" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource CorporateCard}" Margin="0,0,0,10" Padding="16">
            <StackPanel>
              <TextBlock Text="Üretim Parametreleri" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
              <TextBlock Text="Toplam Araç" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="txtVehicleCount" Text="100" Style="{StaticResource NestingInputFieldStyle}" Margin="0,0,0,12"/>
              <TextBlock Text="Günlük Araç" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="txtVehiclesPerDay" Text="10" Style="{StaticResource NestingInputFieldStyle}" Margin="0,0,0,12"/>
              <TextBlock Text="Kerf (mm)" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="txtKerf" Text="5" Style="{StaticResource NestingInputFieldStyle}"
                       PreviewTextInput="IntegerOnly_Preview" Margin="0,0,0,12"/>
              <TextBlock Text="Kelepçe (mm/uç)" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="txtClamp" Text="100" Style="{StaticResource NestingInputFieldStyle}"
                       PreviewTextInput="IntegerOnly_Preview" Margin="0,0,0,12"/>
              <TextBlock Text="Standart Profil Boyu (mm)" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="txtStandardLength" Text="6000" Style="{StaticResource NestingInputFieldStyle}"
                       PreviewTextInput="IntegerOnly_Preview"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource CorporateCard}" Padding="16">
            <StackPanel>
              <TextBlock Text="Üretim Sekansı" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
              <TextBlock Text="Opsiyonel · Örn: 10-10-5-5" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
              <TextBox x:Name="txtCustomSequence" Text="" Style="{StaticResource NestingInputFieldStyle}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Results -->
      <Border Grid.Column="2" Style="{StaticResource CorporateCard}" Padding="0" MinHeight="0" VerticalAlignment="Stretch">
        <Grid MinHeight="0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="0"/>
          </Grid.RowDefinitions>
          <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Kesim Planı" Style="{StaticResource SectionHeader}"
                          FontSize="14" VerticalAlignment="Center"/>
              <CheckBox Grid.Column="1" x:Name="chkMergeIdentical" Content="Benzer Kesimleri Birleştir"
                        Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="11"
                        VerticalAlignment="Center" Click="ChkMergeIdentical_Click" Cursor="Hand"/>
              <ComboBox Grid.Column="3" x:Name="cmbDimensionFilter"
                        Style="{StaticResource CorporateHeaderComboBox}" Width="180"
                        SelectionChanged="DimensionFilter_Changed"/>
            </Grid>
          </Border>
          <DataGrid x:Name="dgResults" Grid.Row="1" Margin="8"
                    Style="{StaticResource CorporateDataGrid}"
                    ColumnHeaderStyle="{StaticResource CorporateDataGridColumnHeader}"
                    CellStyle="{StaticResource CorporateDataGridCell}"
                    RowStyle="{StaticResource CorporateDataGridRow}">
            <DataGrid.Resources>
              <Style TargetType="ScrollViewer">
                <Setter Property="HorizontalScrollBarVisibility" Value="Visible"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
              </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
              <DataGridTextColumn Header="#" Binding="{Binding ProfileIndex}" Width="60"/>
              <DataGridTextColumn x:Name="colQuantity" Header="Adet" Binding="{Binding Quantity}" Width="55" Visibility="Collapsed"/>
              <DataGridTextColumn Header="Ölçü" Binding="{Binding Dimensions}" Width="90"/>
              <DataGridTextColumn Header="Bileşenler" Binding="{Binding Components}" Width="Auto" MinWidth="200"/>
              <DataGridTextColumn Header="Kesimler" Binding="{Binding CutLengths}" Width="Auto" MinWidth="120"/>
              <DataGridTextColumn Header="Kullanım" Binding="{Binding UsedMm, StringFormat={}{0:N0}}" Width="72"/>
              <DataGridTextColumn Header="Fire" Binding="{Binding WasteMm, StringFormat={}{0:N0}}" Width="64"/>
              <DataGridTextColumn Header="%" Binding="{Binding UtilizationPercent, StringFormat={}{0:0.#}}" Width="65"/>
            </DataGrid.Columns>
          </DataGrid>
          <StackPanel x:Name="pnlEmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="&#xE9F5;" Style="{StaticResource EmptyStateIcon}"/>
            <TextBlock Text="Henüz plan yok" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,12,0,4"/>
            <TextBlock Text="Excel seçip Hesapla'ya basın" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Actions -->
      <ScrollViewer Grid.Column="4"
                    MinHeight="0"
                    VerticalAlignment="Stretch"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Background="Transparent"
                    Padding="0,0,4,0"
                    CanContentScroll="False">
        <StackPanel Margin="0,0,0,32">
          <Button x:Name="btnCalculate" Style="{StaticResource PrimaryButton}" Background="{StaticResource NestingAccentBrush}"
                  Click="Calculate_Click" Margin="0,0,0,8" Padding="12,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,6,0"/>
              <TextBlock Text="Hesapla"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource NestingSecondaryActionButton}" Click="FindBestLength_Click" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE76C;" FontFamily="{StaticResource IconFont}" FontSize="11"
                         Foreground="{StaticResource IOAccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="En İyi Boy Analizi" FontFamily="{StaticResource SecondaryFont}" FontSize="12"
                         Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource NestingSecondaryActionButton}" Click="ExportExcel_Click" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE76C;" FontFamily="{StaticResource IconFont}" FontSize="11"
                         Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="Excel Raporu" FontFamily="{StaticResource SecondaryFont}" FontSize="12"
                         Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource NestingSecondaryActionButton}" Click="ExportDailyPlan_Click" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE76C;" FontFamily="{StaticResource IconFont}" FontSize="11"
                         Foreground="{StaticResource NestingAccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="Günlük Plan" FontFamily="{StaticResource SecondaryFont}" FontSize="12"
                         Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource NestingSecondaryActionButton}" Click="ExportSequence_Click" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE76C;" FontFamily="{StaticResource IconFont}" FontSize="11"
                         Foreground="{StaticResource MakeBuyAccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="Sekans Planı" FontFamily="{StaticResource SecondaryFont}" FontSize="12"
                         Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Border Style="{StaticResource CorporateCard}" Padding="16">
            <StackPanel>
              <TextBlock Text="Özet" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
              <TextBlock x:Name="txtSummaryParts" Text="Parça tipi: —" Style="{StaticResource CaptionText}" Margin="0,0,0,6"/>
              <TextBlock x:Name="txtSummaryPieces" Text="Toplam adet: —" Style="{StaticResource CaptionText}" Margin="0,0,0,6"/>
              <TextBlock x:Name="txtSummaryGroups" Text="Profil grubu: —" Style="{StaticResource CaptionText}" Margin="0,0,0,6"/>
              <TextBlock x:Name="txtSummaryDays" Text="Üretim süresi: —" Style="{StaticResource CaptionText}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- Status bar — always visible -->
    <Border Grid.Row="2" Style="{StaticResource PageFooterBar}" Margin="0,10,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="StatusIcon" Text="&#xE930;" FontFamily="{StaticResource IconFont}" FontSize="14"
                   Foreground="{StaticResource NestingAccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   Visibility="Collapsed"/>
        <TextBlock x:Name="txtStatus" Grid.Column="1" Text="" Foreground="{DynamicResource TextBrush}"
                   FontSize="11" VerticalAlignment="Center"/>
        <ProgressBar x:Name="progressBar" Grid.Column="2" Width="100" Height="3" Margin="12,0"
                     IsIndeterminate="True" Visibility="Collapsed"
                     Foreground="{StaticResource NestingAccentBrush}"
                     Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
        <Button x:Name="btnCancel" Grid.Column="3" Content="İptal" Visibility="Collapsed"
                Style="{StaticResource SecondaryButton}" Padding="12,5" Click="Cancel_Click"/>
      </Grid>
    </Border>
  </Grid>
</Page>
