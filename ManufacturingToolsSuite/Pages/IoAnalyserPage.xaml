<Page x:Class="ManufacturingToolsSuite.Pages.IoAnalyserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">

  <ScrollViewer Style="{StaticResource PageContentArea}">
    <Grid Style="{StaticResource PageShell}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Style="{StaticResource PageHeaderBar}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE9D9;" Style="{StaticResource FlatModuleIcon}"
                       Foreground="{StaticResource IOAccentBrush}"/>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="IO Analizi" Style="{StaticResource ModulePageTitle}"/>
              <TextBlock Text="Giriş ve çıkış akış analizi" Style="{StaticResource ModulePageSubtitle}"/>
            </StackPanel>
          </StackPanel>
          <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Padding="16,10" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8E5;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,8,0"/>
              <TextBlock Text="Veri İçe Aktar"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
        <Border Style="{StaticResource StatStripCard}" Margin="0,0,6,0">
          <StackPanel>
            <TextBlock Text="Giriş Noktası" Style="{StaticResource MetricCardLabel}"/>
            <TextBlock Text="—" Style="{StaticResource MetricCardValue}" Foreground="{DynamicResource TextBrush}" FontSize="16"/>
          </StackPanel>
        </Border>
        <Border Style="{StaticResource StatStripCard}" Margin="3,0">
          <StackPanel>
            <TextBlock Text="Çıkış Noktası" Style="{StaticResource MetricCardLabel}"/>
            <TextBlock Text="—" Style="{StaticResource MetricCardValue}" Foreground="{DynamicResource TextBrush}" FontSize="16"/>
          </StackPanel>
        </Border>
        <Border Style="{StaticResource StatStripCard}" Margin="6,0,0,0">
          <StackPanel>
            <TextBlock Text="Darboğaz" Style="{StaticResource MetricCardLabel}"/>
            <TextBlock Text="—" Style="{StaticResource MetricCardValue}" Foreground="{DynamicResource TextBrush}" FontSize="16"/>
          </StackPanel>
        </Border>
      </UniformGrid>

      <Border Grid.Row="2" Style="{StaticResource CorporateCard}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="440">
          <TextBlock Text="&#xE9D9;" Style="{StaticResource EmptyStateIcon}" FontSize="56"
                     Foreground="{StaticResource IOAccentBrush}" Opacity="0.35"/>
          <TextBlock Text="IO Analiz Modülü" FontFamily="{StaticResource PrimaryFont}" FontSize="18"
                     FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                     HorizontalAlignment="Center" Margin="0,16,0,8"/>
          <TextBlock Text="Üretim hattı giriş ve çıkış noktalarını analiz ederek darboğazları tespit edin."
                     FontFamily="{StaticResource SecondaryFont}" FontSize="13"
                     Foreground="{DynamicResource SecondaryTextBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </Grid>
  </ScrollViewer>
</Page>
